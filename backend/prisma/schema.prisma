generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id               String         @id @default(uuid())
  name             String
  slug             String         @unique
  plan             Plan           @default(FREE)
  stripeCustomerId String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  description      String?
  isPublic         Boolean        @default(false)
  logoUrl          String?
  courses          Course[]
  subscriptions    Subscription[]
  users            User[]

  @@index([slug])
  @@index([isPublic])
}

model User {
  id                String       @id @default(uuid())
  email             String       @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              Role         @default(STUDENT)
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organizationId    String
  attempts          Attempt[]
  createdCourses    Course[]     @relation("CourseCreator")
  uploadedMaterials Material[]   @relation("MaterialUploader")
  createdQuestions  Question[]   @relation("QuestionCreator")
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([organizationId])
}

model Course {
  id             String       @id @default(uuid())
  name           String
  description    String?
  isPublished    Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  createdById    String
  isPublic       Boolean      @default(false)
  createdBy      User         @relation("CourseCreator", fields: [createdById], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  materials      Material[]
  questions      Question[]

  @@index([organizationId])
  @@index([createdById])
  @@index([isPublic])
}

model Material {
  id           String   @id @default(uuid())
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int
  createdAt    DateTime @default(now())
  courseId     String
  uploadedById String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("MaterialUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model Question {
  id          String    @id @default(uuid())
  content     String
  hint        String?
  aiGenerated Boolean   @default(false)
  approved    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  courseId    String
  createdById String
  answers     Answer[]
  attempts    Attempt[]
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("QuestionCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([approved])
}

model Answer {
  id         String    @id @default(uuid())
  content    String
  isCorrect  Boolean   @default(false)
  questionId String
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model Attempt {
  id               String   @id @default(uuid())
  isCorrect        Boolean
  createdAt        DateTime @default(now())
  userId           String
  questionId       String
  selectedAnswerIds String[]
  question         Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@index([createdAt])
}

model Subscription {
  id                   String             @id @default(uuid())
  stripeSubscriptionId String             @unique
  stripePriceId        String
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  organizationId       String
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([stripeSubscriptionId])
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}
